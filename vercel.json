{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/.next",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_API_URL": "http://localhost:3000"
  },
  "regions": ["sfo1"],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  }
}
